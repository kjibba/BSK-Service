# Copy this file to .env and edit values before running docker-compose
# Example values (DO NOT use these in production)

# Nginx exposed ports
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Backend
BACKEND_PORT=8000

# MariaDB credentials
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=bsk_service
MYSQL_USER=bsk_user
MYSQL_PASSWORD=change_me_db_password
# Copy this to .env and edit values before running production compose
SECRET_KEY=tilfeldighemmelighet
MYSQL_ROOT_PASSWORD=Skriv3f3il!
MYSQL_DATABASE=bsk_service_db
MYSQL_USER=bsk_user
MYSQL_PASSWORD=Skriv3f3il!
# Database URL for SQLAlchemy (used by the backend). The compose file will make 'db' resolvable.
DATABASE_URL=mysql+mysqlconnector://bsk_user:Skriv3f3il!@db:3306/bsk_service_db

# Backend listen port inside the container (set to 8000 by default).
# To change the host port mapping, edit the ports section in docker-compose.prod.yml
PORT=8000

