MYSQL_ROOT_PASSWORD=localroot
MYSQL_DATABASE=bsk
MYSQL_USER=bsk
MYSQL_PASSWORD=bskpass

# Optional port overrides
# For Nginx-dev (bygget SPA) bruk 5175 så URL matcher dokumentasjon
NGINX_HTTP_PORT=5175
NGINX_HTTPS_PORT=443
BACKEND_PORT=8000

# Alternativ: ekstern utviklingsdatabase
# DB_HOST=host.docker.internal
# DB_PORT=3306
# DB_SYNC=false

# HTTP Basic auth for local Nginx (protects static files and API proxy). Set these
# in your .env.local when you want to require a password for the app.
# BASIC_AUTH_USER=admin
# BASIC_AUTH_PASS=secret
