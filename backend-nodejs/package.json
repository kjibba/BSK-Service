{
  "name": "bsk-service-backend-nodejs",
  "version": "1.0.0",
  "description": "BSK Service App - Node.js Backend",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "tsx watch src/app.ts",
    "migration:generate": "tsx src/data-source.ts migration:generate",
    "migration:run": "tsx src/run-migrations.ts",
  "seed:admin": "tsx src/scripts/seedAdmin.ts",
  "user:set-password": "tsx src/scripts/setPassword.ts",
    "migration:show": "node -e \"require('./dist/data-source.js').AppDataSource.initialize().then(ds=>ds.showMigrations().then(p=>{console.log('Pending:',p); ds.destroy()}))\"",
    "migration:revert": "tsx src/data-source.ts migration:revert"
  },
  "dependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-fileupload": "^1.4.3",
    "express-session": "^1.17.3",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5",
    "nodemailer": "^6.10.1",
    "pdf-lib": "^1.17.1",
    "reflect-metadata": "^0.1.13",
  "typeorm": "^0.3.17",
  "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-fileupload": "^1.4.4",
    "@types/express-session": "^1.17.10",
    "@types/node": "^20.10.4",
    "@types/nodemailer": "^7.0.1",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  },
  "keywords": [
    "bsk",
    "service",
    "backend",
    "nodejs",
    "express",
    "typeorm"
  ],
  "author": "",
  "license": "ISC"
}
